NODE_ENV=development
PORT=5000

# MongoDB — replace with your Atlas connection string
MONGO_URI=mongodb://localhost:27017/teamflow

# JWT — use a long random secret in production
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRE=7d

# Frontend URL for CORS
CLIENT_URL=http://localhost:5173

# Owner setup key — required to register as the first user (Owner).
# Set this to any secret string. Keep it private.
# First registration URL: https://yourapp.com/register?setup=YOUR_KEY
# Leave empty to disable the key check (not recommended in production).
SETUP_KEY=change_this_to_something_secret
